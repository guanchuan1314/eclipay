# EcliPay Environment Configuration
# Copy this file to .env and update values as needed

# =======================
# APPLICATION SETTINGS
# =======================
NODE_ENV=production
# PORT is used internally by the backend service (default: 3000)
PORT=3000

# =======================
# EXTERNAL PORTS (Production Only)
# =======================
# Frontend port exposed to host (default: 3000)
FRONTEND_PORT=3000
# Backend API port exposed to host (default: 3001)
BACKEND_PORT=3001
# PostgreSQL port exposed to host (default: 5432)
POSTGRES_PORT=5432
# Redis port exposed to host (default: 6379)
REDIS_PORT=6379

# =======================
# DOMAIN CONFIGURATION
# =======================
# Primary domain for frontend (used by Traefik for SSL)
FRONTEND_DOMAIN=payment.yourdomain.com
# API domain (can be subdomain or same domain with /api path)
API_DOMAIN=api.yourdomain.com
# Frontend API URL for client-side requests
FRONTEND_API_URL=https://payment.yourdomain.com/api

# =======================
# DATABASE CONFIGURATION
# =======================
# PostgreSQL connection details
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=eclipay
DB_PASSWORD=change-this-secure-password-in-production
DB_NAME=eclipay

# =======================
# REDIS CONFIGURATION
# =======================
# Redis connection details (used for caching and sessions)
REDIS_HOST=redis
REDIS_PORT=6379

# =======================
# SECURITY CONFIGURATION
# =======================
# Encryption key for sensitive data (32+ character string)
ENCRYPTION_KEY=change-this-32-char-encryption-key-in-production-min

# JWT secret for authentication tokens (32+ character string)
JWT_SECRET=change-this-32-char-jwt-secret-in-production-minimum

# API rate limiting (requests per minute per IP)
RATE_LIMIT_TTL=60000
RATE_LIMIT_LIMIT=100

# =======================
# BLOCKCHAIN RPC URLS
# =======================
# Ethereum Mainnet (required for ETH USDT)
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-api-key

# Binance Smart Chain (required for BSC USDT)
BSC_RPC_URL=https://bsc-dataseed.binance.org/

# Polygon (required for Polygon USDT)
POLYGON_RPC_URL=https://polygon-rpc.com/

# Arbitrum One (required for Arbitrum USDT)
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# Optimism (required for Optimism USDT)
OPTIMISM_RPC_URL=https://mainnet.optimism.io

# Avalanche C-Chain (required for Avalanche USDT)
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc

# Tron Network (required for TRC20 USDT)
TRON_RPC_URL=https://api.trongrid.io

# Solana Mainnet (required for Solana USDT)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# TON Network (required for TON Jettons)
TON_RPC_URL=https://toncenter.com/api/v2/jsonRPC

# =======================
# WEBHOOK CONFIGURATION
# =======================
# Default webhook timeout in milliseconds
WEBHOOK_TIMEOUT=30000

# Webhook retry attempts
WEBHOOK_RETRY_ATTEMPTS=3

# Webhook retry delay in milliseconds
WEBHOOK_RETRY_DELAY=5000

# =======================
# MONITORING & LOGGING
# =======================
# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Enable transaction monitoring (true/false)
ENABLE_MONITORING=true

# Transaction confirmation requirements
MIN_CONFIRMATIONS_ETH=12
MIN_CONFIRMATIONS_BSC=15
MIN_CONFIRMATIONS_POLYGON=20
MIN_CONFIRMATIONS_ARBITRUM=1
MIN_CONFIRMATIONS_OPTIMISM=1
MIN_CONFIRMATIONS_AVALANCHE=1
MIN_CONFIRMATIONS_TRON=20
MIN_CONFIRMATIONS_SOLANA=32
MIN_CONFIRMATIONS_TON=1

# =======================
# EMAIL CONFIGURATION (Optional)
# =======================
# SMTP settings for notifications
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your-smtp-password
SMTP_FROM=EcliPay <noreply@yourdomain.com>

# =======================
# DEVELOPMENT SETTINGS
# =======================
# Set to true for development/staging environments
DEBUG=false

# Enable CORS for all origins (development only)
CORS_ORIGIN=https://payment.yourdomain.com

# Database connection pool size
DB_POOL_SIZE=10

# Redis connection pool size
REDIS_POOL_SIZE=10

# =======================
# BACKUP CONFIGURATION
# =======================
# S3-compatible backup settings (optional)
BACKUP_S3_ENDPOINT=https://s3.amazonaws.com
BACKUP_S3_BUCKET=eclipay-backups
BACKUP_S3_ACCESS_KEY=your-access-key
BACKUP_S3_SECRET_KEY=your-secret-key
BACKUP_S3_REGION=us-east-1

# Automatic backup schedule (cron format)
BACKUP_SCHEDULE=0 2 * * *

# =======================
# PERFORMANCE TUNING
# =======================
# Node.js memory limit (in MB)
NODE_OPTIONS=--max-old-space-size=2048

# Worker threads for blockchain monitoring
WORKER_THREADS=4

# Maximum concurrent webhook deliveries
MAX_WEBHOOK_CONCURRENCY=50

# Cache TTL for chain data (in seconds)
CHAIN_CACHE_TTL=300